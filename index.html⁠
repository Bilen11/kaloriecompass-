<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="UTF-8">
    <title>KalorieKompas</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 20px; }
        .container { max-width: 400px; margin: auto; border: 1px solid #ccc; padding: 20px; border-radius: 8px; }
        input, button { width: 100%; padding: 10px; margin: 10px 0; }
    </style>
</head>
<body>

<div class="container">
    <h1>KalorieKompas</h1>
    <input type="number" id="kalorier" placeholder="Indtast kalorier">
    <button onclick="tilfojKalorier()">Tilføj til dagens total</button>
    <h2>Total: <span id="total">0</span> kcal</h2>
</div>

<script>
    let total = 0;
    function tilfojKalorier() {
        let input = document.getElementById('kalorier').value;
        if (input !== "") {
            total += parseInt(input);
            document.getElementById('total').innerText = total;
            document.getElementById('kalorier').value = "";
        }
    }
</script>

</body>
</html>
